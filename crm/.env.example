# BCI CRM System v2 — Environment Variables
# Copy this file to .env.local and fill in actual values

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# DeepSeek AI (optional, for AI content review)
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# Supabase server-side writes (recommended for public AI chat logging)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 火山引擎 Ark（豆包/SeedDream/即梦）—— 内容生产
ARK_API_KEY=your-ark-api-key
ARK_TEXT_ENDPOINT=ep-xxxxxxxx-xxxx        # 豆包文本（文案/选题）
ARK_IMAGE_ENDPOINT=ep-xxxxxxxx-xxxx       # SeedDream 配图
ARK_VIDEO_ENDPOINT=ep-xxxxxxxx-xxxx       # 即梦/Seedance 视频（开通后填入即可启用「🎬 生成视频」）

# Standalone AI assistant WeChat CTA
NEXT_PUBLIC_ADVISOR_WECHAT_ID=your-wechat-id
NEXT_PUBLIC_ADVISOR_WECHAT_QR_URL=https://example.com/wechat-qr.png
